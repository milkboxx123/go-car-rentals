# ── Database ──
# Local dev (Docker): run `npm run docker:up` first
DATABASE_URL="postgresql://gorentals:gorentals@localhost:5433/gorentals"
# Vercel/Neon: auto-provisioned via Vercel Marketplace — do not commit real values

# ── Auth ──
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# ── Postmark ──
POSTMARK_API_KEY="your-postmark-server-api-token"
POSTMARK_FROM_EMAIL="noreply@gorentals.com"

# ── Stripe ──
# Use pk_test_/sk_test_ locally; pk_live_/sk_live_ in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Local: from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── App ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
