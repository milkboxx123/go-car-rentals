generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String
  emailVerified    Boolean  @default(false)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  reservations            Reservation[]
  stripeCustomers         UserStripeCustomer[]
  messages                Message[]
  favorites               Favorite[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reservation {
  id                           String            @id @default(cuid())
  userId                       String
  vehicleId                    String
  locationId                   String
  confirmationNumber           String            @unique
  pickupLocation               String
  startDate                    DateTime
  endDate                      DateTime
  totalAmount                  Int
  status                       ReservationStatus @default(PENDING)
  paymentStatus                PaymentStatus     @default(PENDING)
  stripePaymentIntentId        String?
  stripeDepositPaymentIntentId String?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id])

  @@index([userId])
  @@index([locationId])
  @@map("CustomerReservation")
}

model UserStripeCustomer {
  id               String   @id @default(cuid())
  userId           String
  locationId       String
  stripeCustomerId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@index([locationId])
}

model StripeWebhookEvent {
  id          String   @id
  locationId  String
  eventType   String
  processedAt DateTime @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  body      String
  fromAdmin Boolean  @default(false)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Shared models (admin app owns Location, fleet tables)
// ---------------------------------------------------------------------------

model Location {
  id                   String   @id @default(cuid())
  marketName           String
  locationName         String
  slug                 String   @unique
  addressLine1         String?
  addressLine2         String?
  city                 String
  state                String
  postalCode           String?
  country              String   @default("USA")
  latitude             Float?
  longitude            Float?
  pickupInstructions   String?
  returnInstructions   String?
  airportPickupEnabled Boolean  @default(false)
  deliveryEnabled      Boolean  @default(false)
  isActive             Boolean  @default(true)
  stripePublishableKey         String?
  stripeSecretKeyEncrypted     String?
  stripeWebhookSecretEncrypted String?
  stripeAccountId              String?
  stripePaymentsEnabled        Boolean  @default(false)
  stripeConfiguredAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  reservations     Reservation[]
  stripeCustomers  UserStripeCustomer[]
  webhookEvents    StripeWebhookEvent[]

  @@map("Location")
}

// ---------------------------------------------------------------------------
// Read-only fleet models shared with admin app
// ---------------------------------------------------------------------------

model BookingGroup {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  publicHeadline          String?
  publicDescription       String?
  descriptionShort        String?
  descriptionLong         String?
  heroImageBlobUrl        String?
  cardImageBlobUrl        String?
  imageAltText            String?
  imageSourceType         String?
  seoTitle                String?
  seoDescription          String?
  startingDailyRateCents  Int      @default(0)
  depositCents            Int?
  mileageAllowancePerDay  Int?
  minDays                 Int?
  maxDays                 Int?
  minSeats                Int      @default(2)
  maxSeats                Int      @default(5)
  minBags                 Int      @default(1)
  maxBags                 Int      @default(3)
  seatsMin                Int?
  seatsMax                Int?
  sortOrder               Int      @default(0)
  isActive                Boolean  @default(true)
  isFeatured              Boolean  @default(false)
  locationId              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  vehicleEligibilities VehicleBookingGroupEligibility[]
  media                BookingGroupMedia[]

  @@map("BookingGroup")
}

model BookingGroupMedia {
  id             String  @id @default(cuid())
  bookingGroupId String
  blobUrl        String
  mediaType      String
  altText        String?
  sourceType     String?
  sourceUrl      String?
  credit         String?
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  bookingGroup BookingGroup @relation(fields: [bookingGroupId], references: [id], onDelete: Cascade)

  @@index([bookingGroupId])
  @@map("BookingGroupMedia")
}

model VehicleMake {
  id       String         @id @default(cuid())
  name     String
  slug     String         @unique
  isActive Boolean        @default(true)
  models   VehicleModel[]
  vehicles Vehicle[]

  @@map("VehicleMake")
}

model VehicleModel {
  id           String   @id @default(cuid())
  makeId       String
  name         String
  slug         String
  bodyType     String?
  defaultSeats Int?
  defaultDoors Int?
  isActive     Boolean  @default(true)

  make     VehicleMake @relation(fields: [makeId], references: [id])
  vehicles Vehicle[]

  @@index([makeId])
  @@map("VehicleModel")
}

model Vehicle {
  id           String  @id @default(cuid())
  makeId       String
  modelId      String
  year         Int
  color        String?
  status       String  @default("draft")
  licensePlate String?
  vin          String? @unique
  vinDecodeId  String?
  bodyType     String?
  fuelType     String?
  drivetrain   String?
  engineCylinders     Int?
  engineDisplacement  String?
  engineModel         String?
  transmission        String?
  manufacturerName    String?
  plantCountry        String?
  plantState          String?
  plantCity           String?
  vinLookupStatus     String? @default("not_checked")
  locationId          String?
  archivedAt          DateTime?

  make   VehicleMake  @relation(fields: [makeId], references: [id])
  model  VehicleModel @relation(fields: [modelId], references: [id])

  eligibleGroups VehicleBookingGroupEligibility[]
  availabilityBlocks AvailabilityBlock[]
  reservationAssignments ReservationVehicleAssignment[]

  @@index([makeId])
  @@index([modelId])
  @@map("Vehicle")
}

model VehicleBookingGroupEligibility {
  id             String @id @default(cuid())
  vehicleId      String
  bookingGroupId String
  isPrimary      Boolean @default(false)

  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bookingGroup BookingGroup @relation(fields: [bookingGroupId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, bookingGroupId])
  @@index([bookingGroupId])
  @@map("VehicleBookingGroupEligibility")
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  vehicleId String
  startAt   DateTime
  endAt     DateTime
  reason    String
  source    String   @default("admin_manual")
  notes     String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("AvailabilityBlock")
}

model AdminReservation {
  id           String   @id @default(cuid())
  bookingGroupId String
  status       String   @default("pending")
  pickupAt     DateTime
  returnAt     DateTime

  vehicleAssignments ReservationVehicleAssignment[]

  @@map("Reservation")
}

model ReservationVehicleAssignment {
  id               String   @id @default(cuid())
  reservationId    String
  vehicleId        String
  assignmentStatus String   @default("active")
  assignedAt       DateTime @default(now())
  unassignedAt     DateTime?

  reservation AdminReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([reservationId])
  @@map("ReservationVehicleAssignment")
}
